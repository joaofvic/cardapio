
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the customer, including their name, phone, and saved address.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The customer's full name."
        },
        "phone": {
          "type": "string",
          "description": "The customer's phone number, used as a unique identifier."
        },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "number": { "type": "string" },
            "neighborhood": { "type": "string" },
            "city": { "type": "string", "default": "São Miguel - RN" },
            "complement": { "type": "string" },
            "reference": { "type": "string", "description": "A landmark or point of reference for delivery." }
          }
        }
      },
      "required": ["name", "phone"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's meal order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "total": { "type": "number" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "preparing", "delivery", "completed", "cancelled"],
          "default": "pending"
        },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "address": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "MealPlanLead": {
      "title": "Meal Plan Lead",
      "description": "Information about a customer who sent a meal plan for budget estimation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "textPlan": { "type": "string" },
        "photoDataUri": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "responded"], 
          "default": "pending" 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerName", "status", "createdAt"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the application features.",
      "type": "object",
      "properties": {
        "isAiAnalysisEnabled": { "type": "boolean", "default": true },
        "isCouponsEnabled": { "type": "boolean", "default": true },
        "isVeggieCategoryVisible": { "type": "boolean", "default": true },
        "activeCouponCode": { "type": "string", "default": "ADAS" },
        "couponDiscountPercent": { "type": "number", "default": 50 },
        "nextDeliveryDate": { "type": "string" },
        "orderDeadline": { "type": "string" }
      }
    },
    "Meal": {
      "title": "Meal",
      "description": "A meal available in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "calories": { "type": "number" },
        "imageUrl": { "type": "string" },
        "rating": { "type": "number" },
        "isDairyFree": { "type": "boolean" },
        "isGlutenFree": { "type": "boolean" },
        "isSugarFree": { "type": "boolean" },
        "isArchived": { "type": "boolean", "default": false }
      },
      "required": ["name", "category", "price"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "id": { "type": "string" }
      },
      "required": ["label", "id"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/users/{phoneNumber}": {
      "schema": "UserProfile",
      "description": "Stores user profile information indexed by their phone number."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Stores customer orders."
    },
    "/leads/{leadId}": {
      "schema": "MealPlanLead",
      "description": "Stores leads from meal plan analysis requests."
    },
    "/settings/global": {
      "schema": "SiteSettings",
      "description": "Global website configuration."
    },
    "/meals/{mealId}": {
      "schema": "Meal",
      "description": "Stores the restaurant's menu items."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Stores the product categories."
    }
  }
}
